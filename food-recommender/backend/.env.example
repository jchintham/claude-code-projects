GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
YELP_API_KEY=your_yelp_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
JWT_SECRET=generate_with_node_command_below
PORT=3000

# To generate JWT_SECRET, run this in your terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# YOUTUBE_API_KEY: Enable in Google Cloud Console → APIs & Services → YouTube Data API v3
# (same project as your existing Google Places API key)
